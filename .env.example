OPENAI_API_KEY=sk-...
COLLECTION_NAME=network_docs

# GHCR registry prefix — required for `docker compose pull` to work.
# Format: ghcr.io/<github-owner>/<repo-name>
IMAGE_BASE=ghcr.io/afly007/rag-docs

# Re-ranking (optional — improves result precision, off by default)
# RERANKER=local    # CPU cross-encoder via flashrank; downloads ~100 MB model on first start
# RERANKER=cohere   # Cohere Rerank API; requires COHERE_API_KEY below
# COHERE_API_KEY=

# Trust-tier score penalty for community (tier-4) results returned by search_docs()
# Values < 1.0 apply a penalty; 1.0 disables boosting (0.75 = 25% penalty)
# TIER_BOOST_4=0.75
