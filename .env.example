OPENAI_API_KEY=sk-...
COLLECTION_NAME=distill

# GHCR registry prefix — required for `docker compose pull` to work.
# Format: ghcr.io/<github-owner>/<repo-name>
IMAGE_BASE=ghcr.io/afly007/distill

# Re-ranking (optional — improves result precision, off by default)
# RERANKER=local    # CPU cross-encoder via flashrank; downloads ~100 MB model on first start
# RERANKER=cohere   # Cohere Rerank API; requires COHERE_API_KEY below
# COHERE_API_KEY=

# Trust-tier score penalty for community (tier-4) results returned by search_docs()
# Values < 1.0 apply a penalty; 1.0 disables boosting (0.75 = 25% penalty)
# TIER_BOOST_4=0.75

# Browser clipper API key — required to use the browser extension
# Generate any random string, e.g.: openssl rand -hex 32
# CLIP_API_KEY=your-secret-key-here

# ── Proxy security (Caddy) ───────────────────────────────────────────────────
# Admin authentication — protects /stats and /files with HTTP basic auth.
# Both vars must be set together, or both left unset (auth is disabled).
# Generate a hash:  docker run --rm caddy:2-alpine caddy hash-password --plaintext yourpassword
# ADMIN_USER=admin
# ADMIN_PASSWORD_HASH=JDJhJDE0JGV...

# Rate limit for the /clip endpoint — max requests per IP per minute (default 20)
# CLIP_RATE_LIMIT=20

# ── TLS / Reverse proxy (Caddy) ──────────────────────────────────────────────
# Uncomment COMPOSE_PROFILES to enable the Caddy reverse proxy with TLS.
# Caddy will terminate TLS on :443 and forward to mcp-server internally.
# mcp-server port 8000 remains available for direct HTTP access on the LAN.
#
# COMPOSE_PROFILES=tls

# TLS_MODE: which certificate strategy to use
#   internal  — Caddy's built-in CA issues a self-signed cert.
#               Import Caddy's root cert once into each client's trust store.
#               No domain or external services required.
#               Cert path (to import): caddy_data volume → pki/authorities/local/root.crt
#               Docker shortcut: docker compose cp caddy:/data/pki/authorities/local/root.crt ./caddy-root.crt
#
#   dns       — Let's Encrypt cert via DNS-01 challenge.
#               Requires a real domain and API credentials for your DNS provider.
#               Clients trust it automatically (no cert import needed).
#               Works on private IPs as long as you control DNS.
#
# TLS_MODE=internal
# TLS_DOMAIN=distill.local

# ── DNS challenge settings (TLS_MODE=dns only) ───────────────────────────────
# TLS_DNS_PROVIDER=cloudflare   # cloudflare | route53 | acmedns | digitalocean

# Cloudflare — create an API token with Zone:DNS:Edit for the target zone
# CF_API_TOKEN=

# Route53 — uses AWS SDK credential chain (env vars, instance role, ~/.aws)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ACME-DNS — self-hosted acme-dns server (https://github.com/joohoi/acme-dns)
# ACMEDNS_HOST=https://auth.acme-dns.io

# DigitalOcean
# DO_AUTH_TOKEN=
