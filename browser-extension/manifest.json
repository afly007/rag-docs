{
  "manifest_version": 3,
  "name": "Network Docs Clipper",
  "version": "1.0.0",
  "description": "Save the current page to your Network Docs RAG server with one click.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Network Docs"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
