{
  "manifest_version": 3,
  "name": "Distill Clipper",
  "version": "1.0.0",
  "description": "Save the current page to your Distill knowledge base with one click.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Distill"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
